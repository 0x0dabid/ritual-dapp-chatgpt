# ── Ritual Chain RPC ─────────────────────────────────────────────────────────
NEXT_PUBLIC_RITUAL_CHAIN_ID=1979
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org
